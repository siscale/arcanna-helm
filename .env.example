# ═══════════════════════════════════════════════════════════════════
# Arcanna one-line installer — copy this file to .env, fill in, then:
#     make deploy-all
#
# If envs/$ENV/ doesn't exist yet, deploy-all auto-creates it from
# envs/_template/ using the values below. On subsequent runs your
# edited env files are reused as-is (init-env is idempotent).
# ═══════════════════════════════════════════════════════════════════

# ── Cluster target ─────────────────────────────────────────────────
ENV       = my-new-env
NAMESPACE = arcanna-my-new-env

# ── Env bootstrap (used by `make init-env` on first deploy) ────────
# Storage class must already exist in your cluster.
STORAGE_CLASS = sc-default

# ECK creates services named <cluster>-es-http + secret <cluster>-es-elastic-user.
ES_CLUSTER_NAME = aiops-my-new-env

# NodePorts baked into env YAML (must be unique across envs on same cluster).
PLATFORM_NODE_PORT = 31400
EXPOSER_NODE_PORT  = 31403

# ── Image tags ─────────────────────────────────────────────────────
TAG = v1.78.1
# REST_API_TAG       =
# CORE_FRAMEWORK_TAG =
# MIGRATION_TAG      =
# MODULAR_TAG        =
# MONITORING_TAG     =
# PLATFORM_TAG       =
# MCP_CLIENT_TAG     =
# RAG_TAG            =   # arcanna-rag deployed manually, different cadence

# ── GCR pull secret (required — Arcanna images are private) ───────
GCR_JSON_KEY_FILE = /path/to/gcr-sa.json

# ── Infra credentials ──────────────────────────────────────────────
# Empty on first deploy → auto-generated and saved to K8s secrets.
POSTGRES_USER     =
POSTGRES_PASSWORD =
POSTGRES_DB       =
REDIS_PASSWORD    =

# ── Public URLs of backend + monitoring + platform ─────────────────
# Set explicitly (https://arcanna.mycorp.com) if you have DNS + ingress.
# Leave EMPTY → Makefile flips services to NodePort and auto-builds
# URLs as http://<first-node-ip>:<PORT>.
BACKEND_URL    =
MONITORING_URL =
PLATFORM_URL   =

# NodePorts used only when URLs above are empty.
# Monitoring only exposes the api port externally; shipper stays ClusterIP (internal).
REST_API_NODE_PORT           = 31401
MONITORING_NODE_PORT         = 31402

# ── Admin user (created after migration-end) ───────────────────────
# Empty ADMIN_PASSWORD auto-generates one (printed once on first install).
ADMIN_USERNAME        = admin
ADMIN_PASSWORD        =
ADMIN_EMAIL           = contact@siscale.com
ADMIN_FULL_NAME       = Admin
FORCE_PASSWORD_CHANGE = true
FORCE_USER_CREATION   = false
